global:
  scrape_interval: "{{ prometheus_scrape_interval }}"
  evaluation_interval: "{{ prometheus_scrape_interval }}"

scrape_configs:
  - job_name: 'prometheus_internal'
    static_configs:
      - targets: ['localhost:9090']

  - job_name: 'ec2_python_target'
    static_configs:
      # Ansible will automatically inject the private IP address of the script machine here.
      - targets: ['{{ hostvars[groups["target"][0]]["ansible_default_ipv4"]["address"] }}:9100']
